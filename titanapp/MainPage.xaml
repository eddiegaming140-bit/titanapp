                    <WebView.Source>
                        <HtmlWebViewSource>
                            <HtmlWebViewSource.Html>
                                <![CDATA[
                                <!DOCTYPE html>
                                <html>
                                <head>
                                    <meta name="viewport" content="initial-scale=1,maximum-scale=1,user-scalable=no">
                                    <link href="https://unpkg.com/maplibre-gl@3.0.0/dist/maplibre-gl.css" rel="stylesheet" />
                                    <script src="https://unpkg.com/maplibre-gl@3.0.0/dist/maplibre-gl.js"></script>
                                    <style>
                                        body { margin: 0; padding: 0; background-color: #1a1a1a; }
                                        #map-overview { position: absolute; top: 0; bottom: 0; width: 100%; }
                                        .maplibregl-ctrl-bottom-left, .maplibregl-ctrl-bottom-right { display: none !important; }
                                        
                                        /* Styling for the circular user tracker on the overview map */
                                        .overview-circle {
                                            width: 20px;
                                            height: 20px;
                                            background-color: #4285F4;
                                            border: 3px solid white;
                                            border-radius: 50%;
                                            box-shadow: 0 0 10px rgba(0,0,0,0.5);
                                        }
                                    </style>
                                </head>
                                <body>
                                    <div id="map-overview"></div>
                                    <script>
                                        const overviewMap = new maplibregl.Map({
                                            container: 'map-overview',
                                            style: 'https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json',
                                            center: [15.6214, 58.4109],
                                            zoom: 12, 
                                            pitch: 0, 
                                            bearing: 0
                                        });

                                        // Add navigation controls so the user can zoom and pan easily
                                        overviewMap.addControl(new maplibregl.NavigationControl(), 'top-right');

                                        let overviewMarker;
                                        let isFirstLoad = true;

                                        function updateOverviewLocation(lat, lng) {
                                            const coords = [lng, lat];
                                            
                                            if (!overviewMarker) {
                                                const el = document.createElement('div');
                                                el.className = 'overview-circle';
                                                
                                                overviewMarker = new maplibregl.Marker({ element: el })
                                                    .setLngLat(coords)
                                                    .addTo(overviewMap);
                                            } else {
                                                overviewMarker.setLngLat(coords);
                                            }
                                            
                                            // Only center map on the very first GPS fix.
                                            // This allows the user to pan around freely without snapping back.
                                            if (isFirstLoad) {
                                                overviewMap.jumpTo({ center: coords, zoom: 14 });
                                                isFirstLoad = false;
                                            }
                                        }
                                    </script>
                                </body>
                                </html>
                                ]]>
                            </HtmlWebViewSource.Html>
                        </HtmlWebViewSource>
                    </WebView.Source>
