                            <HtmlWebViewSource.Html>
                                <![CDATA[
                                <!DOCTYPE html>
                                <html>
                                <head>
                                    <meta name="viewport" content="initial-scale=1,maximum-scale=1,user-scalable=no">
                                    <link href="https://unpkg.com/maplibre-gl@3.0.0/dist/maplibre-gl.css" rel="stylesheet" />
                                    <script src="https://unpkg.com/maplibre-gl@3.0.0/dist/maplibre-gl.js"></script>
                                    <style>
                                        body { margin: 0; padding: 0; background-color: #1a1a1a; }
                                        #map { position: absolute; top: 0; bottom: 0; width: 100%; }
                                        .maplibregl-ctrl-bottom-left, .maplibregl-ctrl-bottom-right { display: none !important; }
                                        
                                        /* Enlarged Tilted 3D Navigation Pointer Styling */
                                        .nav-pointer {
                                            width: 60px;
                                            height: 60px;
                                            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32"><circle cx="16" cy="16" r="14" fill="%2300467C" stroke="white" stroke-width="2"/><polygon points="16,5 24,24 16,20 8,24" fill="white"/></svg>');
                                            background-size: contain;
                                            background-repeat: no-repeat;
                                            background-position: center;
                                            filter: drop-shadow(0px 10px 8px rgba(0,0,0,0.65));
                                        }
                                    </style>
                                </head>
                                <body>
                                    <div id="map"></div>
                                    <script>
                                        const map = new maplibregl.Map({
                                            container: 'map',
                                            style: 'https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json',
                                            center: [15.6214, 58.4109],
                                            zoom: 17,
                                            pitch: 65,
                                            bearing: 0
                                        });

                                        let userMarker;
                                        
                                        function updateUserLocation(lat, lng, heading) {
                                            const coords = [lng, lat];
                                            
                                            if (!userMarker) { 
                                                const el = document.createElement('div');
                                                el.className = 'nav-pointer';
                                                
                                                userMarker = new maplibregl.Marker({ 
                                                    element: el,
                                                    rotationAlignment: 'map',
                                                    pitchAlignment: 'map'
                                                })
                                                .setLngLat(coords)
                                                .addTo(map);
                                            } else { 
                                                userMarker.setLngLat(coords); 
                                            }
                                            
                                            const normalizedHeading = (heading !== null && heading !== 'null' && heading !== undefined) ? parseFloat(heading) : 0;
                                            userMarker.setRotation(normalizedHeading);

                                            map.easeTo({
                                                center: coords,
                                                bearing: normalizedHeading,
                                                pitch: 65,
                                                duration: 1000
                                            });
                                        }

                                        function recenterMap() {
                                            if (userMarker) {
                                                map.easeTo({
                                                    center: userMarker.getLngLat(),
                                                    pitch: 65,
                                                    zoom: 17,
                                                    duration: 1000
                                                });
                                            }
                                        }
                                    </script>
                                </body>
                                </html>
                                ]]>
                            </HtmlWebViewSource.Html>
                        </HtmlWebViewSource>
